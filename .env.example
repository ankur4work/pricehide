# Shopify App Credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# App URL (update when deploying)
SHOPIFY_APP_URL=https://your-app-url.com

# Database URL (SQLite for development)
DATABASE_URL="file:./dev.db"

# Scopes required by the app
SCOPES=read_products,read_inventory,read_themes

# Optional: Custom shop domain
# SHOP_CUSTOM_DOMAIN=myshop.com

# Billing — override via env, no code changes needed
# APP_PLAN_NAME=Pro
# APP_PLAN_PRICE=20
# APP_PLAN_CURRENCY=USD
APP_TRIAL_DAYS=3
